// ============================================
// MATTER IN ACTION: GAME DEVELOPMENT
// Real-world game with Matter
// ============================================

// ============================================
// 1. SIMPLE PLATFORMER GAME
// ============================================

struct Player {
    x: float,
    y: float,
    velocity_x: float,
    velocity_y: float,
    on_ground: bool,
    health: int,
    score: int
}

struct Enemy {
    x: float,
    y: float,
    velocity_x: float,
    health: int
}

struct Coin {
    x: float,
    y: float,
    collected: bool
}

let player = Player {
    x: 100.0,
    y: 400.0,
    velocity_x: 0.0,
    velocity_y: 0.0,
    on_ground: true,
    health: 100,
    score: 0
};

let enemies = [];
let coins = [];
let game_running = true;

// ============================================
// 2. GAME LOOP
// ============================================

fn game_loop() -> unit {
    let last_time = time.now();
    
    loop {
        if !game_running {
            break;
        }
        
        let current_time = time.now();
        let delta = (current_time - last_time) / 1000.0;  // Convert to seconds
        last_time = current_time;
        
        // Update
        update_player(delta);
        update_enemies(delta);
        check_collisions();
        
        // Render
        render();
        
        // 60 FPS
        time.sleep(16);
    }
    // Efeitos inferidos: time, io
}

// ============================================
// 3. PLAYER LOGIC
// ============================================

fn update_player(delta: float) -> unit {
    // Gravity
    if !player.on_ground {
        player.velocity_y = player.velocity_y + (980.0 * delta);
    }
    
    // Apply velocity
    player.x = player.x + (player.velocity_x * delta);
    player.y = player.y + (player.velocity_y * delta);
    
    // Ground collision
    if player.y >= 400.0 {
        player.y = 400.0;
        player.velocity_y = 0.0;
        player.on_ground = true;
    }
    
    // Friction
    player.velocity_x = player.velocity_x * 0.9;
}

// Player input
on key_press("left") {
    player.velocity_x = -200.0;
}

on key_press("right") {
    player.velocity_x = 200.0;
}

on key_press("space") {
    if player.on_ground {
        player.velocity_y = -500.0;
        player.on_ground = false;
        print "Jump!";
    }
}

// ============================================
// 4. ENEMY LOGIC
// ============================================

fn spawn_enemy() -> unit {
    let enemy = Enemy {
        x: 800.0,
        y: 400.0,
        velocity_x: -100.0,
        health: 50
    };
    
    enemies.push(enemy);
    print "Enemy spawned!";
    // Efeitos inferidos: io
}

fn update_enemies(delta: float) -> unit {
    for enemy in enemies {
        // Move
        enemy.x = enemy.x + (enemy.velocity_x * delta);
        
        // Remove if off screen
        if enemy.x < -50.0 {
            enemies.remove(enemy);
        }
    }
}

// Spawn enemies periodically
on schedule("*/2 * * * * *") {  // Every 2 seconds
    if game_running {
        spawn_enemy();
    }
}

// ============================================
// 5. COLLISION DETECTION
// ============================================

fn check_collisions() -> unit {
    // Player vs Enemies
    for enemy in enemies {
        if distance(player.x, player.y, enemy.x, enemy.y) < 30.0 {
            player.health = player.health - 10;
            enemies.remove(enemy);
            
            print "Hit! Health: " + player.health;
            
            if player.health <= 0 {
                game_over();
            }
        }
    }
    
    // Player vs Coins
    for coin in coins {
        if !coin.collected and distance(player.x, player.y, coin.x, coin.y) < 20.0 {
            coin.collected = true;
            player.score = player.score + 10;
            
            print "Coin collected! Score: " + player.score;
        }
    }
    // Efeitos inferidos: io
}

fn distance(x1: float, y1: float, x2: float, y2: float) -> float {
    let dx = x2 - x1;
    let dy = y2 - y1;
    return sqrt(dx * dx + dy * dy);
}

// ============================================
// 6. RENDERING
// ============================================

fn render() -> unit {
    // Clear screen
    visual.clear();
    
    // Draw player
    visual.draw_rect(player.x, player.y, 30, 30, "blue");
    
    // Draw enemies
    for enemy in enemies {
        visual.draw_rect(enemy.x, enemy.y, 30, 30, "red");
    }
    
    // Draw coins
    for coin in coins {
        if !coin.collected {
            visual.draw_circle(coin.x, coin.y, 10, "yellow");
        }
    }
    
    // Draw UI
    visual.draw_text(10, 10, "Health: " + player.health, "white");
    visual.draw_text(10, 30, "Score: " + player.score, "white");
    
    // Update display
    visual.pulse("game_canvas");
}

// ============================================
// 7. GAME STATES
// ============================================

fn game_over() -> unit {
    game_running = false;
    
    print "Game Over!";
    print "Final Score: " + player.score;
    
    // Save high score
    let high_score = db.query("SELECT score FROM high_scores ORDER BY score DESC LIMIT 1");
    
    if high_score == null or player.score > high_score.score {
        db.query("INSERT INTO high_scores VALUES (?, ?)", player.score, time.now());
        print "New high score!";
    }
    
    // Show game over screen
    visual.draw_text(300, 300, "GAME OVER", "red");
    visual.draw_text(300, 350, "Score: " + player.score, "white");
    visual.pulse("game_canvas");
    // Efeitos inferidos: io, db, time
}

fn restart_game() -> unit {
    print "Restarting game...";
    
    // Reset player
    player = Player {
        x: 100.0,
        y: 400.0,
        velocity_x: 0.0,
        velocity_y: 0.0,
        on_ground: true,
        health: 100,
        score: 0
    };
    
    // Clear enemies and coins
    enemies = [];
    coins = [];
    
    // Spawn initial coins
    spawn_coins();
    
    // Start game
    game_running = true;
    game_loop();
    // Efeitos inferidos: io, time
}

// ============================================
// 8. LEVEL GENERATION
// ============================================

fn spawn_coins() -> unit {
    for i in range(0, 10) {
        let coin = Coin {
            x: random.float(100.0, 700.0),
            y: random.float(100.0, 400.0),
            collected: false
        };
        coins.push(coin);
    }
    
    print "Coins spawned: " + coins.length();
    // Efeitos inferidos: random, io
}

// ============================================
// 9. MULTIPLAYER (with handlers)
// ============================================

fn multiplayer_game() -> unit {
    print "Starting multiplayer game...";
    
    with logging, tracing {
        // Connect to game server
        websocket.connect("wss://game.server.com/ws", fn(data) {
            let message = json.parse(data);
            
            if message.type == "player_move" {
                // Update other player position
                print "Player moved: " + message.player_id;
            }
            
            if message.type == "enemy_spawn" {
                // Spawn enemy
                spawn_enemy();
            }
        });
        
        // Send player position periodically
        loop {
            websocket.send(json.stringify({
                type: "player_move",
                x: player.x,
                y: player.y
            }));
            
            time.sleep(100);  // 10 times per second
        }
    }
    // Efeitos inferidos: io, network, time
}

// ============================================
// 10. SAVE/LOAD SYSTEM
// ============================================

fn save_game() -> unit {
    print "Saving game...";
    
    let save_data = {
        player: player,
        enemies: enemies,
        coins: coins,
        timestamp: time.now()
    };
    
    db.query("INSERT OR REPLACE INTO saves VALUES (?, ?)",
        "autosave", json.stringify(save_data));
    
    print "Game saved!";
    // Efeitos inferidos: io, db, time
}

fn load_game() -> unit {
    print "Loading game...";
    
    let save = db.query("SELECT data FROM saves WHERE id = 'autosave'");
    
    if save != null {
        let data = json.parse(save.data);
        
        player = data.player;
        enemies = data.enemies;
        coins = data.coins;
        
        print "Game loaded!";
    } else {
        print "No save found";
    }
    // Efeitos inferidos: io, db
}

// Auto-save every 30 seconds
on schedule("*/30 * * * * *") {
    if game_running {
        save_game();
    }
}

// ============================================
// 11. LEADERBOARD
// ============================================

fn show_leaderboard() -> unit {
    print "Loading leaderboard...";
    
    // Get from server
    let response = net.get("https://game.server.com/leaderboard");
    let leaderboard = json.parse(response.body);
    
    print "=== LEADERBOARD ===";
    for i in range(0, leaderboard.length()) {
        let entry = leaderboard[i];
        print (i + 1) + ". " + entry.name + " - " + entry.score;
    }
    
    // Update UI
    visual.pulse("leaderboard");
    // Efeitos inferidos: io, network
}

fn submit_score(name: string, score: int) -> unit {
    print "Submitting score...";
    
    let response = net.post("https://game.server.com/scores", {
        name: name,
        score: score,
        timestamp: time.now()
    });
    
    if response.status == 200 {
        print "Score submitted!";
        show_leaderboard();
    } else {
        print "Failed to submit score";
    }
    // Efeitos inferidos: io, network, time
}

// ============================================
// 12. MAIN
// ============================================

fn main() -> unit {
    print "=== MATTER GAME ===";
    print "";
    
    // Initialize
    visual.run("game");
    visual.surface("game_canvas", 800, 600);
    
    // Spawn initial coins
    spawn_coins();
    
    // Setup menu
    on tap("start_button") {
        restart_game();
    }
    
    on tap("leaderboard_button") {
        show_leaderboard();
    }
    
    on tap("multiplayer_button") {
        multiplayer_game();
    }
    
    print "Game ready!";
    print "Press START to play";
}
