# Lista de tentativas simuladas
let tentativa_1 = 50
let tentativa_2 = 25
let tentativa_3 = 37
let tentativa_4 = 43
let tentativa_5 = 40
let tentativa_6 = 41
let tentativa_7 = 42

# Função para verificar tentativa
fn verificar_tentativa(tentativa, secreto, numero_tentativa) {
    print "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    print "Tentativa #"
    print numero_tentativa
    print "Seu palpite: "
    print tentativa
    
    if tentativa == secreto {
        print "🎉 PARABÉNS! VOCÊ ACERTOU! 🎉"
        return 1
    }
    
    if tentativa < secreto {
        print "📈 Muito baixo! Tente um número MAIOR!"
    }
    
    if tentativa > secreto {
        print "📉 Muito alto! Tente um número MENOR!"
    }
    
    print ""
    return 0
}

# Tentativa 1
set tentativas = tentativas + 1
let resultado = verificar_tentativa(tentativa_1, numero_secreto, tentativas)

if resultado == 0 {
    # Tentativa 2
    set tentativas = tentativas + 1
    set resultado = verificar_tentativa(tentativa_2, numero_secreto, tentativas)
}

if resultado == 0 {
    # Tentativa 3
    set tentativas = tentativas + 1
    set resultado = verificar_tentativa(tentativa_3, numero_secreto, tentativas)
}

if resultado == 0 {
