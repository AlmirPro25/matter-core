    set tentativas = tentativas + 1
    set resultado = verificar_tentativa(tentativa_4, numero_secreto, tentativas)
}

if resultado == 0 {
    # Tentativa 5
    set tentativas = tentativas + 1
    set resultado = verificar_tentativa(tentativa_5, numero_secreto, tentativas)
}

if resultado == 0 {
    # Tentativa 6
    set tentativas = tentativas + 1
    set resultado = verificar_tentativa(tentativa_6, numero_secreto, tentativas)
}

if resultado == 0 {
    # Tentativa 7
