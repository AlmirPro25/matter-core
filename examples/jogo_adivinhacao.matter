# Número secreto (entre 1 e 100)
let numero_secreto = 42
let tentativas = 0
let max_tentativas = 7

print "🎯 Eu pensei em um número entre 1 e 100!"
print "🤔 Você tem 7 tentativas para adivinhar..."
