print "╚════════════════════════════════════════╝"
print ""
print "📊 Total de tentativas: "
print tentativas
print ""

if resultado == 1 {
    print "🏆 VOCÊ É UM MESTRE DA ADIVINHAÇÃO! 🏆"
    
    if tentativas <= 3 {
        print "⭐⭐⭐ INCRÍVEL! Menos de 3 tentativas!"
    }
    
    if tentativas > 3 {
        if tentativas <= 5 {
            print "⭐⭐ MUITO BOM! Entre 4 e 5 tentativas!"
        }
    }
    
    if tentativas > 5 {
        print "⭐ BOM! Mas pode melhorar!"
    }
} else {
