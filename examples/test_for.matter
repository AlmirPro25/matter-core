# Teste de For Loops

print "=== Teste de For Loops ==="

let nums = [1, 2, 3, 4]
let total = 0

for n in nums {
    set total = total + n
    print n
}

print total

print "=== Continue e Break ==="

for n in nums {
    if n == 2 {
        continue
    }
    if n == 4 {
        break
    }
    print n
}

print "=== Fim dos Testes ==="
