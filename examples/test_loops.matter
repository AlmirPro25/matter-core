# Teste de Loops

print "=== Teste 1: While Básico ==="
let i = 0
while i < 5 {
    print i
    set i = i + 1
}

print "=== Teste 2: Loop com Break ==="
let j = 0
loop {
    print j
    set j = j + 1
    if j >= 5 {
        break
    }
}

print "=== Teste 3: Continue ==="
let k = 0
while k < 5 {
    set k = k + 1
    if k == 3 {
        continue
    }
    print k
}

print "=== Teste 4: Nested Loops ==="
let x = 0
while x < 3 {
    let y = 0
    while y < 3 {
        let val = x * 10 + y
        print val
        set y = y + 1
    }
    set x = x + 1
}

print "=== Teste 5: Break em Nested ==="
let a = 0
while a < 5 {
    if a == 3 {
        break
    }
    print a
    set a = a + 1
}

print "=== Fim dos Testes ==="
