# Backend Integration - Demonstração de todos os backends

print "=== Backend Integration Demo ==="
print ""

# 1. Agent Backend (IA/LLM)
print "1. Agent Backend:"
agent.say("Hello from Matter Core!")
print ""

# 2. Math Backend
print "2. Math Backend:"
let power = math.pow(2, 10)
print "2^10 = 1024"
print power
let sqrt_result = math.sqrt(144)
print "sqrt(144) = 12"
print sqrt_result
print ""

# 3. String Backend
print "3. String Backend:"
let text = "hello matter"
let upper = string.upper(text)
print "Upper:"
print upper
let words = string.split(text, " ")
print "Words:"
print words
print ""

# 4. List Backend
print "4. List Backend:"
let items = [5, 2, 8, 1, 9]
let sorted = list.sort(items)
print "Sorted:"
print sorted
let sum = list.sum(items)
print "Sum:"
print sum
print ""

# 5. Time Backend
print "5. Time Backend:"
let timestamp = time.now()
print "Current timestamp:"
print timestamp
print ""

# 6. Random Backend
print "6. Random Backend:"
let rand_int = random.int(100)
print "Random int (0-100):"
print rand_int
let rand_bool = random.bool()
print "Random bool:"
print rand_bool
print ""

# 7. JSON Backend
print "7. JSON Backend:"
let data = [1, 2, 3]
let json_str = json.stringify(data)
print "JSON:"
print json_str
print ""

# 8. Store Backend
print "8. Store Backend:"
store.set("demo_key", "demo_value")
print "Stored: demo_key = demo_value"
let has_key = store.has("demo_key")
print "Has key:"
print has_key
print ""

# 9. Visual Backend
print "9. Visual Backend:"
visual.run("demo_app")
print "[VISUAL] Demo app started"
print ""

# 10. Net Backend
print "10. Net Backend:"
print "[NET] HTTP operations available"
print ""

print "All 10 backends demonstrated!"
print "Matter Core is a complete runtime system."
