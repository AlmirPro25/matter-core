# Polyglot hook: demanda preditiva com Python.
# Mantido isolado para facilitar fallback local sem Python.

fn demand_forecast_local_fallback(hour_slot) {
    if hour_slot >= 18 {
        return 40
    }
    if hour_slot >= 8 {
        return 26
    }
    return 14
}

