let event_log = []

fn publish_event(event_type, payload) {
    event_log.push({
        "type": event_type,
        "payload": payload
    })
}

fn emit_ride_created(ride) {
    publish_event("ride_created", {
        "ride_id": ride["id"],
        "driver_id": ride["driver_id"],
        "rider_id": ride["rider_id"]
    })
}

fn emit_ride_completed(ride) {
    publish_event("ride_completed", {
        "ride_id": ride["id"],
        "fare": ride["fare"]
    })
}
