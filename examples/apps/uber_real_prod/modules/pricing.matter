fn surge_from_ratio(demand, supply) {
    if supply == 0 {
        return 3
    }
    if demand > supply {
        return 2
    }
    return 1
}

fn fare_estimate(distance_km, surge, rider_priority) {
    let base = 8
    let per_km = 4
    let priority_fee = rider_priority
    return ((base + (distance_km * per_km)) * surge) + priority_fee
}
