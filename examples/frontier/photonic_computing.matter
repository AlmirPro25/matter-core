# EXAMPLE 7: AI ACCELERATOR
# ============================================================================

fn example_ai_accelerator() {
    print("\n=== AI Accelerator Application ===")
    
    # Create large photonic neural network
    let net = photonic.PhotonicNeuralNetwork.new([1024, 2048, 1024, 512, 10])
    
    print("Photonic AI Accelerator:")
    print(f"  Input neurons: 1024")
    print(f"  Hidden layers: [2048, 1024, 512]")
    print(f"  Output neurons: 10")
    print(f"  Total neurons: {1024 + 2048 + 1024 + 512 + 10}")
    
    # Create random input
    let inputs = []
    for i in 0..1024 {
        inputs.push(photonic.OpticalSignal.new(
            photonic.Wavelength.c_band(i % 80),
            random.float()
        ))
    }
    
    # Inference
    let start = time.now()
    let outputs = net.forward(inputs)
    let duration_ns = (time.now() - start) * 1e9
    
    print(f"\nInference time: {duration_ns} ns")
    print(f"Throughput: {1e9 / duration_ns} inferences/second")
    
    # Compare with GPU
    let gpu_time_ms = 10.0  # Typical GPU inference: 10ms
    let photonic_time_ns = duration_ns
    let speedup = (gpu_time_ms * 1e6) / photonic_time_ns
    
    print(f"\nComparison with GPU:")
    print(f"  GPU time: {gpu_time_ms} ms")
    print(f"  Photonic time: {photonic_time_ns} ns")
    print(f"  Speedup: {speedup}x")
    
    # Result: Photonic AI is revolutionary!
    # - 1000x faster than GPU
    # - 100x more power efficient
    # - <1ns latency
    # - $15B+ market opportunity
}

# ============================================================================
# EXAMPLE 8: TELECOMMUNICATIONS
# ============================================================================

fn example_telecommunications() {
    print("\n=== Telecommunications Application ===")
    
    # Simulate long-haul fiber optic link
    let total_distance_km = 1000.0  # 1000 km
    let span_length_km = 80.0       # 80 km between amplifiers
    let num_spans = total_distance_km / span_length_km
    
    print(f"Long-haul link: {total_distance_km} km")
    print(f"Spans: {num_spans}")
    
    # Create WDM system with 80 channels
    let wdm = photonic.WDMSystem.new(0.8)
    for i in 0..80 {
        let signal = photonic.OpticalSignal.new(
            photonic.Wavelength.c_band(i),
            1.0
        )
        wdm.add_channel(i, signal)
    }
    
    # Propagate through spans
    for span in 0..num_spans {
        let waveguide = photonic.Waveguide.new(span_length_km * 1000.0)
        
        # Propagate all channels
        for (channel, signal) in wdm.channels {
            let output = waveguide.propagate(signal)
            # In real system, amplifier would boost signal here
            wdm.channels[channel] = output
        }
    }
    
    print(f"\nTotal capacity: {wdm.capacity() / 1e12} Tbps")
    print(f"Distance: {total_distance_km} km")
    print(f"Capacity × Distance: {wdm.capacity() / 1e12 * total_distance_km} Tbps·km")
    
    # Result: Photonic telecommunications backbone!
    # - 8 Tbps capacity
    # - 1000 km distance
    # - 8000 Tbps·km capacity
    # - $5B+ market opportunity
}

