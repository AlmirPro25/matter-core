    print("6. Protein Folding")
    protein_folding()
    print()
    
    print("7. Genetic Circuit Design")
    genetic_circuit()
    print()
    
    print("8. Personalized Medicine")
    personalized_medicine()
    print()
    
    print("9. DNA Data Storage")
    dna_storage()
    print()
    
    print("=== Biological Computing in Matter ===")
    print("✅ DNA/RNA manipulation")
    print("✅ DNA computing (10^18 ops/sec)")
    print("✅ CRISPR simulation")
    print("✅ Genetic algorithms")
    print("✅ Protein folding")
    print("✅ Synthetic biology")
    print("✅ Personalized medicine")
    print("✅ DNA storage (215 PB/gram)")
    print()
    print("Matter: First language with native biological computing!")
}
