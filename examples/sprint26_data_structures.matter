# ============================================================================
# TEST 2: List Length
# ============================================================================

print "=== TEST 2: List Length ==="
let items = [10, 20, 30]
print items.len()  # Expected: 3

# ============================================================================
# TEST 3: List Push
# ============================================================================

print "=== TEST 3: List Push ==="
let stack = [1, 2, 3]
stack.push(4)
print stack.len()  # Expected: 4
print stack[3]     # Expected: 4

# ============================================================================
# TEST 4: List Pop
# ============================================================================

print "=== TEST 4: List Pop ==="
let queue = [10, 20, 30]
let value = queue.pop()
print value        # Expected: 30
print queue.len()  # Expected: 2

