# ============================================================================
# TEST 14: List Operations in Loop
# ============================================================================

print "=== TEST 14: List in Loop ==="
let sum = 0
let values = [1, 2, 3, 4, 5]
let i = 0
while i < 5 {
    sum = sum + values[i]
    i = i + 1
}
print sum  # Expected: 15

# ============================================================================
# TEST 15: List as Function Parameter
# ============================================================================

print "=== TEST 15: List Parameter ==="
fn get_first(list) {
    return list[0]
}

let nums = [100, 200, 300]
let first = get_first(nums)
print first  # Expected: 100

