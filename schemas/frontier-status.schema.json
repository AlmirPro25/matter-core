{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://matter-lang.org/schemas/frontier-status.schema.json",
  "title": "Matter Frontier Backend Reality Status",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "ok",
    "kind",
    "summary",
    "backends"
  ],
  "properties": {
    "$schema": {
      "const": "schemas/frontier-status.schema.json"
    },
    "schema_version": {
      "const": 1
    },
    "ok": {
      "const": true
    },
    "kind": {
      "const": "frontier_status"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_non_stub",
        "all_simulated",
        "any_hardware"
      ],
      "properties": {
        "all_non_stub": {
          "type": "boolean"
        },
        "all_simulated": {
          "type": "boolean"
        },
        "any_hardware": {
          "type": "boolean"
        }
      }
    },
    "backends": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quantum",
        "photonic",
        "neuromorphic",
        "wetware"
      ],
      "properties": {
        "quantum": {
          "$ref": "#/$defs/frontierBackend"
        },
        "photonic": {
          "$ref": "#/$defs/frontierBackend"
        },
        "neuromorphic": {
          "$ref": "#/$defs/frontierBackend"
        },
        "wetware": {
          "$ref": "#/$defs/frontierBackend"
        }
      }
    }
  },
  "$defs": {
    "frontierBackend": {
      "type": "object",
      "required": [
        "backend",
        "model",
        "mode",
        "stub",
        "hardware",
        "simulated",
        "capabilities"
      ],
      "properties": {
        "backend": {
          "type": "string"
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "stub": {
          "const": false
        },
        "hardware": {
          "const": false
        },
        "simulated": {
          "const": true
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
