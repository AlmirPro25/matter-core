{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://matter-lang.org/schemas/frontier-simulation-quality.schema.json",
  "title": "Matter Frontier Simulation Quality",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "ok",
    "kind",
    "summary",
    "checks",
    "evidence",
    "performance"
  ],
  "properties": {
    "$schema": {
      "const": "schemas/frontier-simulation-quality.schema.json"
    },
    "schema_version": {
      "const": 1
    },
    "ok": {
      "type": "boolean"
    },
    "kind": {
      "const": "frontier_simulation_quality"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_simulated",
        "any_hardware",
        "quality_level",
        "implemented_modules",
        "planned_modules"
      ],
      "properties": {
        "all_simulated": {
          "const": true
        },
        "any_hardware": {
          "const": false
        },
        "quality_level": {
          "type": "integer",
          "minimum": 1
        },
        "implemented_modules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "planned_modules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "checks": {
      "type": "object"
    },
    "evidence": {
      "type": "object"
    },
    "performance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit",
        "probe_count",
        "total_elapsed_ns",
        "slowest_probe",
        "probes"
      ],
      "properties": {
        "unit": {
          "const": "ns"
        },
        "probe_count": {
          "type": "integer",
          "minimum": 1
        },
        "total_elapsed_ns": {
          "type": "integer",
          "minimum": 1
        },
        "slowest_probe": {
          "$ref": "#/$defs/probeTiming"
        },
        "probes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/probeTiming"
          }
        }
      }
    }
  },
  "$defs": {
    "probeTiming": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "elapsed_ns"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "elapsed_ns": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
