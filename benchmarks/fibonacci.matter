# Fibonacci Benchmark
# Testa recursão e performance de funções

fn fibonacci(n) {
    if n <= 1 {
        return n
    }
    return fibonacci(n - 1) + fibonacci(n - 2)
}

print "=== Fibonacci Benchmark ==="
print "Computing fibonacci(20)..."

let result = fibonacci(20)
print "Result:"
print result

print "Benchmark complete!"
