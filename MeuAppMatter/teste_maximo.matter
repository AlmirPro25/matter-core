// ===== 7. NEURAL NETWORK + TRIG =====
print "[7] Neural Network com Trigonometria"

fn sigmoid(x) {
    let e_neg_x = math.pow(math.e(), 0.0 - x)
    return 1.0 / (1.0 + e_neg_x)
}

fn neuron_sigmoid(inputs, weights, bias) {
    let i = 0
    let sum = 0.0
    while i < inputs.len() {
        set sum = sum + (inputs[i] * weights[i])
        set i = i + 1
    }
    return sigmoid(sum + bias)
}

let sig_out = neuron_sigmoid([0.5, 0.8], [0.4, 0.6], -0.2)
print "  sigmoid neuron([0.5,0.8]) = " + sig_out
let sin_val = math.sin(math.pi() / 4.0)
print "  sin(pi/4) = " + sin_val
set total = total + 1
set ok = ok + 1
print "  ✅"
print " "

// ===== 8. HTML GENERATOR =====
print "[8] Gerador de Pagina Web Completa"

fn tag(name, content) {
    return "<" + name + ">" + content + "</" + name + ">"
}

fn div_styled(bg, text) {
    return "<div style='background:" + bg + ";padding:12px;margin:8px;border-radius:8px;'>" + text + "</div>"
}

let page = "<!DOCTYPE html>"
set page = page + tag("html", tag("head", tag("title", "Matter Dashboard")) + tag("body", div_styled("#1e293b", tag("h1", "Matter Core")) + div_styled("#0f172a", "Neural Output: " + sig_out) + div_styled("#1e3a5f", "Map Keys: " + map.size(merged) + " entries") + div_styled("#1a2e1a", "List Range: " + list.range(5))))

let page_size = string.len(page)
print "  HTML gerado: " + page_size + " bytes"
set total = total + 1
set ok = ok + 1
print "  ✅"
print " "

