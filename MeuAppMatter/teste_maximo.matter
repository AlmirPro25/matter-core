// ===== 4. TYPE CONVERSION =====
print "[4] Type: Conversão entre Tipos"
let str_to_int = type.to_int("42")
let float_to_int = type.to_int(3.99)
let int_to_float = type.to_float(7)
let int_to_str = type.to_string(1024)
let is_int = type.is_int(42)
let is_str = type.is_string("hello")
print "  to_int('42')   = " + str_to_int
print "  to_int(3.99)   = " + float_to_int
print "  to_float(7)    = " + int_to_float
print "  to_string(1024)= " + int_to_str
print "  is_int(42)     = " + is_int
print "  is_string('x') = " + is_str
