// ===== ROUND 15: String Processing Pipeline =====
print "[ROUND 15] Pipeline de Processamento de Texto"

let raw = "  Hello, Matter Core World!  "
let step1 = string.trim(raw)
let step2 = string.upper(step1)
let step3 = string.replace(step2, "WORLD", "UNIVERSE")
let step4 = string.split(step3, " ")
let step5 = string.join(" | ", step4)
let step6 = string.starts_with(step5, "HELLO")
let step7 = string.ends_with(step5, "UNIVERSE!")
let step8 = string.index_of(step5, "MATTER")
let step9 = string.substring(step5, 0, 5)
let step10 = string.len(step5)

print "  trim     -> " + step1
print "  upper    -> " + step2
print "  replace  -> " + step3
print "  split    -> " + step4
print "  join     -> " + step5
print "  starts?  -> " + step6
print "  ends?    -> " + step7
print "  indexOf  -> " + step8
print "  substr   -> " + step9
print "  len      -> " + step10
set survived = survived + 1
print "  SOBREVIVEU ✅"
print " "

