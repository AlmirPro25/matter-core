// ===== ROUND 11: Sorting Stress =====
print "[ROUND 11] Sort de 200 números aleatórios"

fn generate_random_list(n) {
    let result = []
    let i = 0
    while i < n {
        let val = random.int(0, 10000)
        set result = list.push(result, val)
        set i = i + 1
    }
    return result
}

let chaos = generate_random_list(200)
let sorted = list.sort(chaos)
let first = sorted[0]
let last = sorted[199]
print "  200 números gerados e ordenados"
print "  Menor: " + first + " | Maior: " + last

// Verificar que está realmente ordenado
let is_sorted = true
let k = 0
while k < 199 {
    if sorted[k] > sorted[k + 1] {
        set is_sorted = false
    }
    set k = k + 1
}
print "  Verificação de ordem: " + is_sorted
set survived = survived + 1
print "  SOBREVIVEU ✅"
print " "

// ===== ROUND 12: HTML Generator Complex =====
print "[ROUND 12] Gerador HTML complexo com loop"

fn generate_table(rows, cols) with io {
    let html = "<table border='1'>"
    let r = 0
    while r < rows {
        set html = html + "<tr>"
        let c = 0
        while c < cols {
            let val = (r * cols) + c
            set html = html + "<td>" + val + "</td>"
            set c = c + 1
        }
        set html = html + "</tr>"
        set r = r + 1
    }
    set html = html + "</table>"
    return html
}

let table = generate_table(20, 10)
let table_len = string.len(table)
print "  Tabela 20x10 gerada: " + table_len + " bytes"
set survived = survived + 1
print "  SOBREVIVEU ✅"
print " "

