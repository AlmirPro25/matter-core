// ===== ROUND 1: Recursão Profunda (Fibonacci) =====
print "[ROUND 1] Recursão Profunda - Fibonacci"

fn fib(n) {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}

let f10 = fib(10)
let f15 = fib(15)
let f20 = fib(20)
print "  fib(10) = " + f10
print "  fib(15) = " + f15
print "  fib(20) = " + f20
set survived = survived + 1
print "  SOBREVIVEU ✅"
print " "

// ===== ROUND 2: Fatorial com números grandes =====
print "[ROUND 2] Fatorial - Números Gigantes"

fn factorial(n) {
    if n <= 1 { return 1 }
    return n * factorial(n - 1)
}

let f5 = factorial(5)
let f10 = factorial(10)
let f20 = factorial(20)
print "  5!  = " + f5
print "  10! = " + f10
print "  20! = " + f20
set survived = survived + 1
print "  SOBREVIVEU ✅"
print " "

// ===== ROUND 3: String Concatenação Massiva =====
print "[ROUND 3] String Concat - 500 iterações"

fn build_massive_string(n) {
    let s = ""
    let i = 0
    while i < n {
        set s = s + "X"
        set i = i + 1
    }
    return s
}

let big = build_massive_string(500)
let big_len = string.len(big)
print "  Tamanho: " + big_len + " chars"
