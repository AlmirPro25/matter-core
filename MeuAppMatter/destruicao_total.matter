// ===== ROUND 5: Map Stress - 100 chaves =====
print "[ROUND 5] Map Stress - 100 chaves"

fn build_big_map(n) with io {
    let m = map.new()
    let i = 0
    while i < n {
        let key = "key_" + i
        set m = map.set(m, key, i * i)
        set i = i + 1
    }
    return m
}

let big_map = build_big_map(100)
let map_sz = map.size(big_map)
let val_50 = map.get(big_map, "key_50")
print "  100 chaves inseridas, size=" + map_sz
print "  map.get('key_50') = " + val_50
set survived = survived + 1
print "  SOBREVIVEU ✅"
print " "

