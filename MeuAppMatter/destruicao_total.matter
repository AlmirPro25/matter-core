// ===== ROUND 7: Rede Neural Profunda 5 camadas =====
print "[ROUND 7] Neural Network - 5 Camadas (Deep MLP)"

fn sigmoid(x) {
    let neg = 0.0 - x
    let e_val = math.pow(math.e(), neg)
    return 1.0 / (1.0 + e_val)
}

fn dense_layer(inputs, weights_matrix, biases) with io {
    let outputs = []
    let j = 0
    while j < biases.len() {
        let sum = 0.0
        let i = 0
        let ws = weights_matrix[j]
        while i < inputs.len() {
            set sum = sum + (inputs[i] * ws[i])
            set i = i + 1
        }
        set sum = sum + biases[j]
        set outputs = list.push(outputs, sigmoid(sum))
        set j = j + 1
    }
    return outputs
}

let x = [0.5, 0.3, 0.8, 0.1]
// Camada 1: 4->3
let l1 = dense_layer(x, [[0.2, -0.1, 0.4, 0.3], [0.5, 0.1, -0.3, 0.2], [-0.1, 0.6, 0.2, -0.4]], [0.1, -0.2, 0.3])
print "  L1: " + l1
// Camada 2: 3->3
let l2 = dense_layer(l1, [[0.3, -0.2, 0.5], [0.1, 0.4, -0.1], [-0.3, 0.2, 0.6]], [0.0, 0.1, -0.1])
print "  L2: " + l2
// Camada 3: 3->2
let l3 = dense_layer(l2, [[0.4, -0.3, 0.2], [-0.1, 0.5, 0.3]], [0.1, 0.0])
print "  L3: " + l3
// Camada 4: 2->2
let l4 = dense_layer(l3, [[0.6, -0.2], [0.3, 0.4]], [-0.1, 0.2])
print "  L4: " + l4
// Camada 5: 2->1 (output)
let l5 = dense_layer(l4, [[0.7, 0.3]], [0.0])
print "  L5 (output): " + l5
set survived = survived + 1
print "  SOBREVIVEU ✅"
print " "

