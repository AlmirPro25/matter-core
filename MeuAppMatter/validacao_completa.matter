// ===== 7. REDE NEURAL =====
print "[7] Rede Neural (Forward Pass)"

fn relu(x) {
    if x > 0.0 { return x }
    return 0.0
}

fn neuronio(entradas, pesos, bias) {
    let i = 0
    let soma = 0.0
    while i < entradas.len() {
        set soma = soma + (entradas[i] * pesos[i])
        set i = i + 1
    }
    return relu(soma + bias)
}

fn inferir(x1, x2) with io {
    let inp = [x1, x2]
    let h1 = neuronio(inp, [0.8, -0.4], 0.1)
    let h2 = neuronio(inp, [-0.2, 0.9], -0.3)
    let out = neuronio([h1, h2], [1.5, 0.7], 0.2)
    print "  h1=" + h1 + "  h2=" + h2 + "  out=" + out
    return out
}

let nn = inferir(1.0, 0.5)
set total = total + 1
set ok = ok + 1
print "  ✅"
print " "

