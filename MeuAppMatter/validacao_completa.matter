// ===== 9. STRING CONCAT + HTML =====
print "[9] Gerador de HTML com concat dinamica"

fn html_tag(tag, conteudo) {
    return "<" + tag + ">" + conteudo + "</" + tag + ">"
}

let titulo = html_tag("h1", "Matter Core Dashboard")
let corpo = html_tag("p", "Motor compilado e estavel")
let pagina = html_tag("html", html_tag("body", titulo + corpo))
let tam = string.len(pagina)
print "  HTML: " + tam + " bytes"
set total = total + 1
set ok = ok + 1
print "  ✅"
print " "

