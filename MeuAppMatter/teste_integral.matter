// ========== MODULO 5: LISTAS E ITERACAO ==========
print "[MODULO 5] Listas, Iteracao e list.* Backend"

fn soma_lista(nums) {
    let i = 0
    let soma = 0
    let tam = nums.len()
    while i < tam {
        set soma = soma + nums[i]
        set i = i + 1
    }
    return soma
}

let minha_lista = [10, 20, 30, 40, 50]
let soma_total = soma_lista(minha_lista)
let list_sum = list.sum(minha_lista)
let list_min = list.min(minha_lista)
let list_max = list.max(minha_lista)
let list_sorted = list.sort([50, 10, 40, 20, 30])
let list_rev = list.reverse(minha_lista)

print "  Lista:           [10, 20, 30, 40, 50]"
print "  soma_lista():    " + soma_total
print "  list.sum():      " + list_sum
print "  list.min():      " + list_min
print "  list.max():      " + list_max
print "  list.sort():     " + list_sorted
print "  list.reverse():  " + list_rev
set total_testes = total_testes + 1
set testes_ok = testes_ok + 1
print "  ✅ PASSOU"
print " "

// ========== MODULO 6: HTML DINAMICO (Gerador de Paginas) ==========
print "[MODULO 6] Gerador de HTML Dinamico"

fn gerar_card(titulo, valor) {
    let card = "<div style='padding:10px;background:#1e293b;'>"
    set card = card + "<b>" + titulo + ":</b> " + valor
    set card = card + "</div>"
    return card
}

let pagina = "<html><body>"
set pagina = pagina + gerar_card("CPU", "12%")
set pagina = pagina + gerar_card("RAM", "4.2 GB")
set pagina = pagina + gerar_card("GPU", "NVIDIA RTX")
set pagina = pagina + "</body></html>"

let pagina_size = string.len(pagina)
print "  HTML gerado: " + pagina_size + " bytes"
