// ========== MODULO 2: REDE NEURAL (Forward Pass) ==========
print "[MODULO 2] Rede Neural Profunda (3 camadas)"

fn ativacao_relu(x) {
    if x > 0.0 {
        return x
    }
    return 0.0
}

fn calcular_neuronio(entradas, pesos, bias) {
    let tamanho = entradas.len()
    let i = 0
    let soma = 0.0
    while i < tamanho {
        let x = entradas[i]
        let w = pesos[i]
        set soma = soma + (x * w)
        set i = i + 1
    }
    set soma = soma + bias
    return ativacao_relu(soma)
}

fn forward_pass(s1, s2) with io {
    let inputs = [s1, s2]
    let h1 = calcular_neuronio(inputs, [0.8, -0.4], 0.1)
    let h2 = calcular_neuronio(inputs, [-0.2, 0.9], -0.3)
    let output = calcular_neuronio([h1, h2], [1.5, 0.7], 0.2)
    print "  Camada Oculta: h1=" + h1 + " h2=" + h2
    print "  Saida Neural:  " + output
    return output
}

let neural_result = forward_pass(1.0, 0.5)
set total_testes = total_testes + 1
set testes_ok = testes_ok + 1
print "  ✅ PASSOU"
print " "

