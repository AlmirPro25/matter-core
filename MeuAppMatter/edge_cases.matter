// TESTE 8: Recursão com acumulador (tail-call pattern)
print "[EDGE 8] Recursão com acumulador"

fn sum_recursive(n, acc) {
    if n <= 0 { return acc }
    return sum_recursive(n - 1, acc + n)
}

let sum_500 = sum_recursive(500, 0)
let sum_1000 = sum_recursive(1000, 0)
print "  sum(1..500)  = " + sum_500
print "  sum(1..1000) = " + sum_1000
print "  SOBREVIVEU ✅"
print " "

