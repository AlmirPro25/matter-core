// TESTE 10: Mega pipeline - tudo junto
print "[EDGE 10] Mega Pipeline - TUDO junto"

fn process_data(name, scores) with io {
    // 1. Math
    let pi = math.pi()
    let angle = pi / 4.0
    let sin_v = math.sin(angle)

    // 2. List ops
    let total = list.sum(scores)
    let avg = total / scores.len()
    let sorted = list.sort(scores)
    let best = sorted[scores.len() - 1]

    // 3. String ops
    let upper_name = string.upper(name)
    let report = upper_name + " | avg=" + avg + " | best=" + best + " | sin(45°)=" + sin_v

    // 4. Map
    let result = map.new()
    set result = map.set(result, "name", upper_name)
    set result = map.set(result, "average", avg)
    set result = map.set(result, "best_score", best)
    set result = map.set(result, "total", total)

    // 5. JSON
    let json_out = json.stringify(result)

    // 6. File
    let f = file.write("pipeline_output.json", json_out)

    // 7. Read back
    let read_back = file.read("pipeline_output.json")

    // 8. Cleanup
    let del = file.delete("pipeline_output.json")

    // 9. Type check
    let t = type.of(result)

    print "  Report: " + report
    print "  JSON:   " + json_out
    print "  File roundtrip: " + (read_back == json_out)
    print "  Type:   " + t

    return result
}

let final_result = process_data("Almir", [95, 88, 92, 97, 90, 85, 93, 91])
print "  SOBREVIVEU ✅"
print " "

